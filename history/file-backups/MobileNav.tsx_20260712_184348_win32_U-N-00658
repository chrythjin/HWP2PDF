"use client";

// ---------------------------------------------------------------------------
// MobileNav — keyboard-operable mobile navigation for authenticated users.
//
// Shows a hamburger button below the md breakpoint. When opened, a disclosure
// panel renders the same links as the desktop nav plus the AuthNav actions.
// The trigger is a real <button> with aria-expanded/aria-controls. Escape
// closes the panel and restores focus to the trigger. Tab cycles within the
// panel; the panel traps focus while open. The current route link is marked
// aria-current="page" via usePathname.
// ---------------------------------------------------------------------------

import { useCallback, useEffect, useId, useRef, useState } from "react";
import Link from "next/link";
import { usePathname } from "next/navigation";
import { useAuth } from "@/auth/useAuth";
import AuthNav from "./AuthNav";

const NAV_LINKS = [
  { href: "/", label: "홈" },
  { href: "/history", label: "변환 이력" },
  { href: "/board", label: "게시판" },
] as const;

export default function MobileNav() {
  const { user, loading } = useAuth();
  const pathname = usePathname();
  const [open, setOpen] = useState(false);
  const triggerRef = useRef<HTMLButtonElement | null>(null);
  const panelRef = useRef<HTMLDivElement | null>(null);
  const panelId = useId();

  // Close on route change so the panel never lingers across navigations.
  // We close on link click instead of watching pathname in an effect, which
  // avoids the react-hooks/set-state-in-effect lint rule and is more
  // predictable: the panel closes the instant a navigation is requested.
  const closePanel = useCallback(() => setOpen(false), []);

  // Restore focus to the trigger when the panel closes after being open.
  const wasOpenRef = useRef(false);
  useEffect(() => {
    if (wasOpenRef.current && !open) {
      triggerRef.current?.focus();
    }
    wasOpenRef.current = open;
  }, [open]);

  const handleTriggerKey = useCallback((event: React.KeyboardEvent<HTMLButtonElement>) => {
    if (event.key === "Escape" && open) {
      event.preventDefault();
      setOpen(false);
    }
  }, [open]);

  const handlePanelKey = useCallback((event: React.KeyboardEvent<HTMLDivElement>) => {
    if (event.key !== "Escape" || !open) return;
    event.preventDefault();
    setOpen(false);
  }, [open]);

  // While the panel is open, keep Tab focus inside it.
  const handleTabTrap = useCallback((event: React.KeyboardEvent<HTMLDivElement>) => {
    if (event.key !== "Tab" || !open) return;
    const panel = panelRef.current;
    if (!panel) return;

    const focusables = Array.from(
      panel.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    );
    if (focusables.length === 0) return;

    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;

    if (event.shiftKey) {
      if (active === first || !panel.contains(active)) {
        event.preventDefault();
        last.focus();
      }
    } else {
      if (active === last) {
        event.preventDefault();
        first.focus();
      }
    }
  }, [open]);

  // Only authenticated users get the mobile nav. While auth is loading or the
  // user is anonymous, render nothing — the desktop nav is hidden below md,
  // and anonymous users have no authenticated links to show anyway.
  if (loading || !user) return null;

  const isCurrent = (href: string) => (href === "/" ? pathname === "/" : pathname?.startsWith(href) ?? false);

  return (
    <div className="md:hidden" data-testid="mobile-nav">
      <button
        ref={triggerRef}
        type="button"
        aria-expanded={open}
        aria-controls={panelId}
        aria-haspopup="menu"
        aria-label={open ? "내비게이션 닫기" : "내비게이션 열기"}
        onClick={() => setOpen((prev) => !prev)}
        onKeyDown={handleTriggerKey}
        className="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
        data-testid="mobile-nav-trigger"
      >
        {open ? (
          <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2} aria-hidden="true">
            <path strokeLinecap="round" strokeLinejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        ) : (
          <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2} aria-hidden="true">
            <path strokeLinecap="round" strokeLinejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        )}
      </button>

      {open && (
        <div
          ref={panelRef}
          id={panelId}
          role="menu"
          aria-label="모바일 내비게이션"
          onKeyDown={(e) => {
            handlePanelKey(e);
            handleTabTrap(e);
          }}
          className="absolute top-16 left-0 right-0 z-50 border-b border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 shadow-lg"
          data-testid="mobile-nav-panel"
        >
          <nav className="max-w-6xl mx-auto px-6 py-4 flex flex-col space-y-1" aria-label="모바일 주 내비게이션">
            {NAV_LINKS.map((link) => (
              <Link
                key={link.href}
                href={link.href}
                role="menuitem"
                aria-current={isCurrent(link.href) ? "page" : undefined}
                onClick={closePanel}
                className={`block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 ${
                  isCurrent(link.href)
                    ? "bg-blue-50 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400"
                    : "text-zinc-600 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-900"
                }`}
                data-testid={`mobile-nav-link-${link.href === "/" ? "home" : link.href.slice(1)}`}
              >
                {link.label}
              </Link>
            ))}
            <div className="pt-3 mt-2 border-t border-zinc-200 dark:border-zinc-800">
              <AuthNav />
            </div>
          </nav>
        </div>
      )}
    </div>
  );
}