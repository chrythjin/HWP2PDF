// UploadSession CRUD
// ---------------------------------------------------------------------------

describe("UploadSession CRUD", () => {
  let store: MemoryJobStore;

  beforeEach(() => {
    store = new MemoryJobStore();
  });

  it("creates and retrieves an upload session by jobId", async () => {
    const session = await store.createUploadSession(baseUploadSession());
    expect(session.jobId).toBe("job-session-1");

    const fetched = await store.getUploadSession("job-session-1");
    expect(fetched).toBeDefined();
    expect(fetched?.accessTokenHash).toBe("hash-session");
  });

  it("returns null when session does not exist", async () => {
    const fetched = await store.getUploadSession("nonexistent");
    expect(fetched).toBeNull();
  });

  it("completeUploadSession sets completedAt and merges updates", async () => {
    await store.createUploadSession(baseUploadSession());
    const completed = await store.completeUploadSession("job-session-1", {
      fileName: "renamed.hwp",
    });
    expect(completed).toBeDefined();
    expect(completed?.completedAt).toBeDefined();
    expect(completed?.fileName).toBe("renamed.hwp");
  });

  it("completeUploadSession returns null when session does not exist", async () => {
    const result = await store.completeUploadSession("nonexistent");
    expect(result).toBeNull();
  });

  it("UploadSession mismatch — getUploadSession returns null for wrong jobId", async () => {
    await store.createUploadSession(baseUploadSession({ jobId: "real-job" }));
    const fetched = await store.getUploadSession("wrong-job");
    expect(fetched).toBeNull();
  });

  it("uploadSessions map is separate from jobs map", async () => {
    // A job and a session can share the same jobId without colliding.
    await store.createJob(baseUserJob({ jobId: "shared-id", userId: "user-A" }));
    await store.createUploadSession(baseUploadSession({ jobId: "shared-id", ownerType: "user", userId: "user-A" }));

    const job = await store.getJob("shared-id");
    const session = await store.getUploadSession("shared-id");
    expect(job).toBeDefined();
    expect(session).toBeDefined();
    expect(job?.originalFileName).toBe("doc.hwp");
    expect(session?.fileName).toBe("anon.hwp");
  });

  it("expireUploadSessions removes sessions that have expired before the given time", async () => {
    const past = new Date(Date.now() - 1000).toISOString();
    const future = new Date(Date.now() + UPLOAD_SESSION_TTL_MS).toISOString();

    await store.createUploadSession(baseUploadSession({ jobId: "expired-1", expiresAt: past }));
    await store.createUploadSession(baseUploadSession({ jobId: "active-1", expiresAt: future }));

    const removed = await store.expireUploadSessions();
    expect(removed).toBeGreaterThanOrEqual(1);

    const expired = await store.getUploadSession("expired-1");
    const active = await store.getUploadSession("active-1");
    expect(expired).toBeNull();
    expect(active).toBeDefined();
  });

  it("expireUploadSessions with explicit before parameter", async () => {
    const t0 = Date.now();
    await store.createUploadSession(
      baseUploadSession({ jobId: "s1", expiresAt: new Date(t0 + 10000).toISOString() }),
    );

    // before = now should not remove s1 (expires in future relative to now)
    const removed1 = await store.expireUploadSessions(new Date(t0));
    expect(removed1).toBe(0);

    // before = t0 + 20000 should remove s1
    const removed2 = await store.expireUploadSessions(new Date(t0 + 20000));
    expect(removed2).toBe(1);
    const fetched = await store.getUploadSession("s1");
    expect(fetched).toBeNull();
  });
});

