  const now = Date.now();
  return {
    jobId: "job-user-1",
    originalFileName: "doc.hwp",
    sourcePath: "tmp/uploads/doc.hwp",
    status: "queued",
    progress: 60,
    expiresAt: new Date(now + DEFAULT_DOWNLOAD_TTL_MS).toISOString(),
    createdAt: new Date(now).toISOString(),
    updatedAt: new Date(now).toISOString(),
    ownerType: "user",
    userId: "user-123",
    downloadExpiresAt: new Date(now + DEFAULT_DOWNLOAD_TTL_MS).toISOString(),
    metadataExpiresAt: new Date(now + DEFAULT_METADATA_RETENTION_MS).toISOString(),
    ...overrides,
  };
}

function baseAnonymousJob(overrides: Partial<JobRecord> = {}): JobRecord {
  const now = Date.now();
  return {
    jobId: "job-anon-1",
    originalFileName: "anon.hwp",
    sourcePath: "tmp/uploads/anon.hwp",
    status: "queued",
    progress: 60,
    expiresAt: new Date(now + DEFAULT_DOWNLOAD_TTL_MS).toISOString(),
    createdAt: new Date(now).toISOString(),
    updatedAt: new Date(now).toISOString(),
    ownerType: "anonymous",
