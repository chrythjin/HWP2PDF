describe("listJobsByUser", () => {
  let store: MemoryJobStore;

  beforeEach(() => {
    store = new MemoryJobStore();
  });

  it("returns only the specified user's jobs", async () => {
    await store.createJob(baseUserJob({ jobId: "a1", userId: "user-A" }));
    await store.createJob(baseUserJob({ jobId: "a2", userId: "user-A" }));
    await store.createJob(baseUserJob({ jobId: "b1", userId: "user-B" }));

    const jobs = await store.listJobsByUser("user-A");
    expect(jobs).toHaveLength(2);
    expect(jobs.every((j) => j.userId === "user-A")).toBe(true);
  });

  it("excludes deleted/tombstoned jobs by default", async () => {
    await store.createJob(baseUserJob({ jobId: "a1", userId: "user-A" }));
    await store.createJob(baseUserJob({ jobId: "a2", userId: "user-A" }));
    await store.markJobDeleted("a1", "user-A");

    const jobs = await store.listJobsByUser("user-A");
    expect(jobs).toHaveLength(1);
    expect(jobs[0].jobId).toBe("a2");
  });

  it("returns active tombstones to their owner only when includeDeleted=true", async () => {
    await store.createJob(baseUserJob({ jobId: "a1", userId: "user-A" }));
    await store.markJobDeleted("a1", "user-A");

    const jobs = await store.listJobsByUser("user-A", { includeDeleted: true });
    expect(jobs).toHaveLength(1);
    expect(jobs[0]).toMatchObject({ jobId: "a1", ownerType: "user", userId: "user-A", status: "deleted" });
  });

  it("excludes anonymous jobs", async () => {
    await store.createJob(baseUserJob({ jobId: "a1", userId: "user-A" }));
    await store.createJob(baseAnonymousJob({ jobId: "x1" }));

    const jobs = await store.listJobsByUser("user-A");
    expect(jobs).toHaveLength(1);
    expect(jobs[0].ownerType).toBe("user");
  });

  it("returns empty array for user with no jobs", async () => {
    const jobs = await store.listJobsByUser("nobody");
    expect(jobs).toEqual([]);
  });

  it("sorts by createdAt descending (newest first)", async () => {
    vi.useFakeTimers();
    vi.setSystemTime(new Date(2026, 0, 1, 0, 0, 0));
    await store.createJob(baseUserJob({ jobId: "old", userId: "user-A" }));

    vi.setSystemTime(new Date(2026, 0, 1, 0, 0, 5));
    await store.createJob(baseUserJob({ jobId: "new", userId: "user-A" }));

    vi.useRealTimers();

    const jobs = await store.listJobsByUser("user-A");
    expect(jobs[0].jobId).toBe("new");
    expect(jobs[1].jobId).toBe("old");
  });
});

