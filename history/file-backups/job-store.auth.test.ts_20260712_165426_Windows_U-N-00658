describe("getJobForUser", () => {
  let store: MemoryJobStore;

  beforeEach(() => {
    store = new MemoryJobStore();
  });

  it("returns job when userId matches", async () => {
    await store.createJob(baseUserJob({ jobId: "j1", userId: "user-A" }));
    const job = await store.getJobForUser("j1", "user-A");
    expect(job).toBeDefined();
    expect(job?.userId).toBe("user-A");
  });

  it("returns null when userId does not match", async () => {
    await store.createJob(baseUserJob({ jobId: "j1", userId: "user-A" }));
    const job = await store.getJobForUser("j1", "user-B");
    expect(job).toBeNull();
  });

  it("returns null for anonymous-owned job", async () => {
    await store.createJob(baseAnonymousJob({ jobId: "j1" }));
    const job = await store.getJobForUser("j1", "user-A");
    expect(job).toBeNull();
  });

  it("returns null when job does not exist", async () => {
    const job = await store.getJobForUser("nonexistent", "user-A");
    expect(job).toBeNull();
  });

  it("returns null for deleted (tombstoned) job", async () => {
    await store.createJob(baseUserJob({ jobId: "j1", userId: "user-A" }));
    await store.markJobDeleted("j1", "user-A");
    const job = await store.getJobForUser("j1", "user-A");
    expect(job).toBeNull();
  });
});

