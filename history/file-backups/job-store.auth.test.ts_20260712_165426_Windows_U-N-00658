// markJobDeleted
// ---------------------------------------------------------------------------

describe("markJobDeleted", () => {
  let store: MemoryJobStore;

  beforeEach(() => {
    store = new MemoryJobStore();
  });

  it("stores only privacy-safe tombstone fields", async () => {
    await store.createJob(
      baseUserJob({
        jobId: "j1",
        userId: "user-A",
        originalFileName: "secret.hwp",
        sourcePath: "tmp/uploads/secret.hwp",
        resultPath: "tmp/results/secret.pdf",
        originalObjectPath: "originals/j1/secret.hwp",
        resultObjectPath: "results/j1/secret.pdf",
        downloadUrl: "http://x.pdf",
        accessTokenHash: "hash-that-must-not-survive",
        message: "private failure detail",
      }),
    );
    const before = Date.now();
    const deleted = await store.markJobDeleted("j1", "user-A");
    const after = Date.now();

    expect(deleted).toBeDefined();
    expect(deleted).toEqual(
      expect.objectContaining({
        jobId: "j1",
        originalFileName: "[deleted]",
        sourcePath: "[deleted]",
        status: "deleted",
        progress: 0,
        deletedBy: "user-A",
      }),
    );
    expect(deleted?.status).toBe("deleted");
    expect(deleted?.deletedAt).toBeDefined();
    expect(deleted?.deletedBy).toBe("user-A");
    expect(deleted?.tombstoneUntil).toBeDefined();
    expect(deleted?.createdAt).toBeDefined();
    expect(deleted?.updatedAt).toBe(deleted?.deletedAt);
    expect(deleted?.expiresAt).toBeDefined();
    expect(deleted?.downloadUrl).toBeUndefined();
    expect(deleted?.resultPath).toBeUndefined();
    expect(deleted?.resultObjectPath).toBeUndefined();
    expect(deleted?.originalObjectPath).toBeUndefined();
    expect(deleted?.ownerType).toBe("user");
    expect(deleted?.userId).toBe("user-A");
    expect(deleted?.accessTokenHash).toBeUndefined();
    expect(deleted?.downloadExpiresAt).toBeUndefined();
    expect(deleted?.metadataExpiresAt).toBeDefined();
    expect(deleted?.message).toBeUndefined();
    expect(Object.keys(deleted!).sort()).toEqual([
      "createdAt",
      "deletedAt",
      "deletedBy",
      "expiresAt",
      "jobId",
      "metadataExpiresAt",
      "originalFileName",
      "ownerType",
      "progress",
      "sourcePath",
      "status",
      "tombstoneUntil",
      "updatedAt",
      "userId",
    ]);

    const deletedAtMs = Date.parse(deleted!.deletedAt!);
    expect(deletedAtMs).toBeGreaterThanOrEqual(before);
    expect(deletedAtMs).toBeLessThanOrEqual(after);

    const tombstoneMs = Date.parse(deleted!.tombstoneUntil!);
    expect(tombstoneMs - deletedAtMs).toBe(TOMBSTONE_RETENTION_MS);
  });

  it("returns null when job does not exist", async () => {
    const result = await store.markJobDeleted("nonexistent", "user-A");
    expect(result).toBeNull();
  });

  it("is idempotent — repeated delete succeeds and updates deletedAt", async () => {
    await store.createJob(baseUserJob({ jobId: "j1", userId: "user-A" }));
    const first = await store.markJobDeleted("j1", "user-A");
    expect(first?.status).toBe("deleted");

    // Second delete should not throw and should remain deleted.
    const second = await store.markJobDeleted("j1", "user-A");
    expect(second?.status).toBe("deleted");
    expect(second?.deletedAt).toBeDefined();
  });

  it("worker no-op on deleted job — updateJob does not resurrect a deleted job", async () => {
    await store.createJob(baseUserJob({ jobId: "j1", userId: "user-A" }));
    await store.markJobDeleted("j1", "user-A");

    // Simulate a worker calling updateJob after deletion.
    const updated = await store.updateJob("j1", {
      status: "completed",
      progress: 100,
      downloadUrl: "http://late.pdf",
    });

    // The worker update should not resurrect the job from deleted state.
    expect(updated?.status).toBe("deleted");
    expect(updated?.downloadUrl).toBeUndefined();
  });
});

// ---------------------------------------------------------------------------
// Expired download auto-clear
// ---------------------------------------------------------------------------

describe("expired download auto-clear", () => {
  let store: MemoryJobStore;

  beforeEach(() => {
    store = new MemoryJobStore();
  });

  it("getJob auto-transitions to expired and clears downloadUrl when downloadExpiresAt passes", async () => {
    const past = new Date(Date.now() - 1000).toISOString();
    await store.createJob(
      baseUserJob({
        jobId: "j1",
        status: "completed",
        progress: 100,
        downloadUrl: "http://old.pdf",
        downloadExpiresAt: past,
        expiresAt: past,
      }),
    );

    const job = await store.getJob("j1");
    expect(job?.status).toBe("expired");
    expect(job?.downloadUrl).toBeUndefined();
  });

  it("getJob does not expire a job whose downloadExpiresAt is in the future", async () => {
    const future = new Date(Date.now() + DEFAULT_DOWNLOAD_TTL_MS).toISOString();
    await store.createJob(
      baseUserJob({
        jobId: "j1",
        status: "completed",
        progress: 100,
        downloadUrl: "http://ok.pdf",
        downloadExpiresAt: future,
        expiresAt: future,
      }),
    );

    const job = await store.getJob("j1");
    expect(job?.status).toBe("completed");
    expect(job?.downloadUrl).toBe("http://ok.pdf");
  });
});

