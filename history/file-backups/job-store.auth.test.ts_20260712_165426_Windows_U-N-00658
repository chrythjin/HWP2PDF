describe("isMetadataExpired", () => {
  it("returns false when metadataExpiresAt is in the future", () => {
    const job = baseUserJob({ metadataExpiresAt: new Date(Date.now() + 1000).toISOString() });
    expect(isMetadataExpired(job)).toBe(false);
  });

  it("returns true when metadataExpiresAt is in the past", () => {
    const job = baseUserJob({ metadataExpiresAt: new Date(Date.now() - 1000).toISOString() });
    expect(isMetadataExpired(job)).toBe(true);
  });

  it("returns false when metadataExpiresAt is undefined (legacy job)", () => {
    const job = baseUserJob();
    delete (job as Partial<JobRecord>).metadataExpiresAt;
    expect(isMetadataExpired(job)).toBe(false);
  });
});

describe("isDownloadExpired", () => {
  it("returns false when downloadExpiresAt is in the future", () => {
    const job = baseUserJob({ downloadExpiresAt: new Date(Date.now() + 1000).toISOString() });
    expect(isDownloadExpired(job)).toBe(false);
  });

  it("returns true when downloadExpiresAt is in the past", () => {
    const job = baseUserJob({ downloadExpiresAt: new Date(Date.now() - 1000).toISOString() });
    expect(isDownloadExpired(job)).toBe(true);
  });

  it("falls back to expiresAt when downloadExpiresAt is undefined", () => {
    const job = baseUserJob({ expiresAt: new Date(Date.now() - 1000).toISOString() });
    delete (job as Partial<JobRecord>).downloadExpiresAt;
    expect(isDownloadExpired(job)).toBe(true);
  });
});

// ---------------------------------------------------------------------------
// Tombstone filtering in listJobsByUser
// ---------------------------------------------------------------------------

describe("tombstone filtering", () => {
  let store: MemoryJobStore;

  beforeEach(() => {
    store = new MemoryJobStore();
  });

  it("listJobsByUser excludes jobs whose tombstoneUntil has passed (purged)", async () => {
    // A job deleted long ago whose tombstone has expired.
    const past = new Date(Date.now() - TOMBSTONE_RETENTION_MS - 1000).toISOString();
    await store.createJob(
      baseUserJob({
        jobId: "old-deleted",
        userId: "user-A",
        status: "deleted",
        deletedAt: past,
        deletedBy: "user-A",
        tombstoneUntil: past,
      }),
    );

    const jobs = await store.listJobsByUser("user-A", { includeDeleted: true });
    // Even with includeDeleted, a purged tombstone (tombstoneUntil passed) should be excluded.
    expect(jobs.find((j) => j.jobId === "old-deleted")).toBeUndefined();
  });

  it("listJobsByUser returns active tombstones when includeDeleted=true", async () => {
    await store.createJob(baseUserJob({ jobId: "j1", userId: "user-A" }));
    await store.markJobDeleted("j1", "user-A");

    const jobs = await store.listJobsByUser("user-A", { includeDeleted: true });
    expect(jobs.find((j) => j.jobId === "j1")).toMatchObject({ status: "deleted", userId: "user-A" });
  });
});
