// ---------------------------------------------------------------------------
// Fetch mock helpers.
// ---------------------------------------------------------------------------

const originalFetch = globalThis.fetch;

function mockFetchResponse(url: string, status: number, body: unknown) {
  (globalThis.fetch as Mock).mockImplementation(async (input: string | URL) => {
    const u = String(input);
    if (u.includes(url)) {
      return new Response(JSON.stringify(body), {
        status,
        headers: { "Content-Type": "application/json" },
      });
    }
    return new Response("not found", { status: 404 });
  });
}

function mockFetchImplementation(handler: (url: string, _init?: RequestInit) => Response) {
  (globalThis.fetch as Mock).mockImplementation(async (input: string | URL, init?: RequestInit) => {
    return handler(String(input), init);
  });
}

function renderWithAuth(ui: React.ReactElement) {
  return render(<AuthProvider>{ui}</AuthProvider>);
}

