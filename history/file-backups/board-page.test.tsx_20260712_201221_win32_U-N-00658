// ---------------------------------------------------------------------------
// Mock firebase/auth and @/lib/firebase.
//
// fetchWithAuth uses `auth.currentUser` from @/lib/firebase, so we mock the
// auth singleton to return our mockUser as currentUser. The AuthProvider
// uses onAuthStateChanged from firebase/auth.
// ---------------------------------------------------------------------------

interface MockUserOptions {
  uid?: string;
  email?: string;
  admin?: boolean;
  boardModerator?: boolean;
}

function createMockUser(options: MockUserOptions = {}): User {
  const uid = options.uid ?? "test-uid";
  const claims: Record<string, unknown> = {};
  if (options.admin) claims.admin = true;
  if (options.boardModerator) claims.boardModerator = true;

  const tokenResult = {
    token: "mock-id-token",
    claims: { uid, ...claims },
    issuedAtTime: "",
    expirationTime: "",
    signInProvider: "password",
    signInSecondFactor: null,
  } as unknown as IdTokenResult;

  return {
    uid,
    email: options.email ?? "test@example.com",
    getIdToken: vi.fn().mockResolvedValue("mock-id-token"),
    getIdTokenResult: vi.fn().mockResolvedValue(tokenResult),
  } as unknown as User;
}

// Use vi.hoisted to create mutable state that survives vi.mock hoisting.
const { authStateCallbackRef, mockCurrentUserRef } = vi.hoisted(() => ({
  authStateCallbackRef: { current: null as ((user: User | null) => void) | null },
  mockCurrentUserRef: { current: null as User | null },
}));

function setMockCurrentUser(user: User | null) {
  mockCurrentUserRef.current = user;
}

vi.mock("firebase/auth", () => ({
  onAuthStateChanged: vi.fn((_auth: unknown, cb: (user: User | null) => void) => {
    authStateCallbackRef.current = cb;
    return () => {
      authStateCallbackRef.current = null;
    };
  }),
  signInWithEmailAndPassword: vi.fn(),
  createUserWithEmailAndPassword: vi.fn(),
  signOut: vi.fn(),
  getAuth: vi.fn(() => ({})),
}));

vi.mock("firebase/app", () => ({
  initializeApp: vi.fn(() => ({})),
  getApps: vi.fn(() => [{}]),
  getApp: vi.fn(() => ({})),
}));

vi.mock("@/lib/firebase", () => {
  const mockAuth = {
    get currentUser() {
      return mockCurrentUserRef.current;
    },
  };

  return {
    getFirebaseAuth: vi.fn(() => mockAuth),
    auth: mockAuth,
    isFirebaseConfigured: true,
  };
});

// Mock next/navigation useRouter and useParams.
