    it("submits PATCH with Authorization on save", async () => {
      const mockUser = createMockUser({ uid: "user-1" });
      setMockCurrentUser(mockUser);

      mockFetchImplementation((url, init) => {
        if (url.includes("/v1/board/posts/post-1") && (!init?.method || init.method === "GET")) {
          return new Response(
            JSON.stringify({
              id: "post-1",
              title: "Original Title",
              body: "Original body",
              category: "general",
              authorId: "user-1",
              authorName: "Test User",
              createdAt: "2026-06-20T10:00:00.000Z",
              updatedAt: "2026-06-20T10:00:00.000Z",
            }),
            { status: 200, headers: { "Content-Type": "application/json" } },
          );
        }
        if (url.includes("/v1/board/posts/post-1") && init?.method === "PATCH") {
          return new Response(
            JSON.stringify({
              id: "post-1",
              title: "Updated Title",
              body: "Updated body",
              category: "general",
              authorId: "user-1",
              authorName: "Test User",
              createdAt: "2026-06-20T10:00:00.000Z",
              updatedAt: "2026-06-21T10:00:00.000Z",
            }),
            { status: 200, headers: { "Content-Type": "application/json" } },
          );
        }
        return new Response("not found", { status: 404 });
      });

      renderWithAuth(<BoardEditPage />);

      act(() => {
        authStateCallbackRef.current?.(mockUser);
      });

      await waitFor(() => {
        expect(screen.getByTestId("board-edit-title")).toBeInTheDocument();
      });

      await act(async () => {
        fireEvent.change(screen.getByTestId("board-edit-title"), {
          target: { value: "Updated Title" },
        });
      });

      await act(async () => {
        fireEvent.click(screen.getByTestId("board-edit-submit"));
      });

      const calls = (globalThis.fetch as Mock).mock.calls;
      const patchCall = calls.find(
        ([url, init]) =>
          String(url).includes("/v1/board/posts/post-1") && init?.method === "PATCH",
      );
      expect(patchCall).toBeDefined();

      const init = patchCall![1] as RequestInit;
      const headers = init.headers as Headers;
      expect(headers.get("Authorization")).toBe("Bearer mock-id-token");

      const body = JSON.parse(init.body as string);
      expect(body.title).toBe("Updated Title");
      // Author fields must NOT be in the PATCH body.
      expect(body.authorId).toBeUndefined();
      expect(body.authorName).toBeUndefined();
    });
